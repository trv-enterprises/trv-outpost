{$DOMAIN:localhost} {
    encode gzip

    # Optional TLS directive, injected from the environment. Empty by default
    # → today's behavior (HTTP on :80 for DOMAIN=:80/localhost, or public ACME
    # when DOMAIN is a public hostname). The deployer can supply a `tls { … }`
    # block to choose the cert source for HTTPS. Caddy substitutes {$ENV}
    # placeholders verbatim before parsing, so a multi-line value works.
    #
    # Examples (set via the CADDY_TLS_DIRECTIVE env var on the client container):
    #   - Tailscale (.ts.net) cert — publicly-trusted, zero browser warning,
    #     no ACME challenge; needs tailscaled reachable from the container and
    #     "HTTPS Certificates" enabled on the tailnet:
    #         DOMAIN=<node>.<tailnet>.ts.net
    #         CADDY_TLS_DIRECTIVE=tls {
    #             get_certificate tailscale
    #         }
    #   - Internal CA cert for a HOSTNAME (one-time per-device root-CA trust):
    #         CADDY_TLS_DIRECTIVE=tls internal
    # Do NOT use a bare-IP DOMAIN for HTTPS — the resulting IP-SAN cert is
    # rejected by Chromium/Firefox at the handshake. Use a hostname.
    {$CADDY_TLS_DIRECTIVE}

    # API proxy to Go backend
    handle /api/* {
        reverse_proxy server:3001
    }

    # WebSocket support for streaming endpoints
    handle /api/streams/* {
        reverse_proxy server:3001
    }

    # Health check proxy
    handle /health {
        reverse_proxy server:3001
    }

    # Swagger proxy
    handle /swagger/* {
        reverse_proxy server:3001
    }

    # MCP/SSE proxy (disable buffering for streaming)
    handle /mcp/* {
        reverse_proxy server:3001 {
            flush_interval -1
        }
    }

    # Docs site (Docusaurus) — served by the Go server from the bundled
    # /app/udoc/build. Both the bare /docs hit and asset subpaths need
    # handlers so they reach the Go server instead of falling through
    # to the SPA fallback below.
    handle /docs {
        reverse_proxy server:3001
    }
    handle /docs/* {
        reverse_proxy server:3001
    }

    # SPA fallback — must be last and wrapped in its own terminal handle
    # so Caddy's directive ordering doesn't hoist try_files above the
    # /docs handlers. handle blocks are first-match-wins, so once a
    # /docs request lands in the block above, this one is skipped.
    handle {
        root * /srv
        try_files {path} /index.html
        file_server

        # index.html: always revalidate (304 if unchanged, fresh copy on new build)
        @html path /index.html /
        header @html Cache-Control "no-cache"

        # Cache static assets with hashed filenames
        @assets path /assets/*
        header @assets Cache-Control "public, max-age=31536000, immutable"
    }
}
