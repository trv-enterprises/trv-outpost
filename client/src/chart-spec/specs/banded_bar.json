{
  "schema_version": "1",
  "chart_type": "banded_bar",
  "library": "echarts",
  "display": {
    "label": "Banded Bar Chart",
    "icon": "ChartLineData",
    "description": "Levey-Jennings / control-chart style — time-series with per-row mean + SD bands"
  },
  "capabilities": {
    "requires_x_axis": true,
    "requires_y_axis": false,
    "multiple_y_axis": false,
    "single_axis_n_columns": false,
    "has_pivot_series": false,
    "has_axis_labels": false,
    "has_x_axis_format": true,
    "has_time_bucket": false,
    "has_sort_limit": false,
    "has_visible_columns": false,
    "has_filters": true,
    "has_aggregation": false,
    "has_sliding_window": false,
    "has_legend_config": true,
    "has_tooltip_config": false,
    "has_axis_range": false,
    "has_thresholds": false
  },
  "sections": [
    {
      "id": "data_mapping",
      "label": "Data Mapping",
      "subsections": [
        {
          "id": "timestamp_group",
          "label": "Timestamp",
          "layout": "row-4",
          "fields": [
            {
              "id": "x_axis_column",
              "binds": "data_mapping.x_axis",
              "type": "column_select",
              "label": "Timestamp column",
              "required": true,
              "helperText": "The horizontal (time) axis. One column per row."
            },
            {
              "id": "x_axis_format",
              "binds": "data_mapping.x_axis_format",
              "type": "enum",
              "label": "Timestamp format",
              "default": "chart",
              "options": [
                { "value": "chart", "label": "Auto (date + time)" },
                { "value": "chart_time", "label": "Time only" },
                { "value": "chart_date", "label": "Date only" },
                { "value": "raw", "label": "Raw value" }
              ]
            }
          ]
        },
        {
          "id": "band_columns_group",
          "label": "Band Columns",
          "helperText": "Pick a band scheme, then map each band to a per-row column. Each row carries its own band values, so the envelope moves with the data. Only the center column is required.",
          "layout": "single-column",
          "fields": [
            {
              "id": "band_scheme",
              "binds": "data_mapping.band_columns",
              "type": "band_scheme",
              "label": "Band scheme"
            }
          ]
        }
      ]
    },
    {
      "id": "chart_options",
      "label": "Chart Options",
      "subsections": [
        {
          "id": "style_group",
          "label": "Visual style",
          "layout": "single-column",
          "fields": [
            {
              "id": "banded_bar_style",
              "binds": "options.bandedBarStyle",
              "type": "enum",
              "label": "Visual style",
              "default": "time_series",
              "options": [
                { "value": "time_series", "label": "Time Series — line + dots, full-width bands (default)" },
                { "value": "column_filled", "label": "Column (filled) — vertical column per timestamp, no borders" },
                { "value": "column_outlined", "label": "Column (outlined) — vertical column with band borders" },
                { "value": "column_box", "label": "Column (box) — inner band only, line with tick at value" }
              ]
            }
          ]
        },
        {
          "id": "legend_config",
          "label": "Legend",
          "helperText": "Shows a key for the Mean / ±1 SD / ±2 SD bands.",
          "layout": "row-4",
          "fields": [
            {
              "id": "legend_show",
              "binds": "options.legend.show",
              "type": "boolean",
              "label": "Show legend",
              "default": true
            },
            {
              "id": "legend_position",
              "binds": "options.legend.position",
              "type": "enum",
              "label": "Position",
              "default": "top",
              "helperText": "Left/right reserve ~135px of plot width for the legend column.",
              "options": [
                { "value": "top", "label": "Top" },
                { "value": "bottom", "label": "Bottom" },
                { "value": "left", "label": "Left" },
                { "value": "right", "label": "Right" }
              ],
              "visibleWhen": { "field": "legend_show", "operator": "truthy" }
            }
          ]
        }
      ]
    }
  ]
}
