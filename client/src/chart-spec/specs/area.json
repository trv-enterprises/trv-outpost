{
  "schema_version": "1",
  "chart_type": "area",
  "library": "echarts",
  "display": {
    "label": "Area Chart",
    "icon": "ChartArea",
    "description": "Line chart with filled area beneath"
  },
  "capabilities": {
    "requires_x_axis": true,
    "requires_y_axis": true,
    "multiple_y_axis": true,
    "single_axis_n_columns": true,
    "has_pivot_series": true,
    "has_axis_labels": true,
    "has_x_axis_format": true,
    "has_time_bucket": true,
    "has_sort_limit": true,
    "has_visible_columns": false,
    "has_filters": true,
    "has_aggregation": true,
    "has_sliding_window": true,
    "has_legend_config": true,
    "has_tooltip_config": true,
    "has_axis_range": true,
    "has_thresholds": true
  },
  "sections": [
    {
      "id": "data_mapping",
      "label": "Data Mapping",
      "subsections": [
        {
          "id": "x_axis_group",
          "label": "X-axis",
          "layout": "row-4",
          "fields": [
            {
              "id": "x_axis_column",
              "binds": "data_mapping.x_axis",
              "type": "column_select",
              "label": "X-axis column",
              "required": true,
              "helperText": "Usually a timestamp."
            },
            {
              "id": "x_axis_label",
              "binds": "data_mapping.x_axis_label",
              "type": "text",
              "label": "X-axis label",
              "default": "",
              "placeholder": "Leave empty to hide"
            },
            {
              "id": "x_axis_format",
              "binds": "data_mapping.x_axis_format",
              "type": "enum",
              "label": "Timestamp format",
              "default": "auto",
              "options": [
                {
                  "value": "auto",
                  "label": "Auto (fits the data)"
                },
                {
                  "value": "chart",
                  "label": "Date + Time (1/15 10:30)"
                },
                {
                  "value": "chart_time",
                  "label": "Time Only (10:30 AM)"
                },
                {
                  "value": "chart_time_seconds",
                  "label": "Time + Seconds (10:30:05 AM)"
                },
                {
                  "value": "chart_date",
                  "label": "Date Only (Jan 15)"
                },
                {
                  "value": "chart_datetime",
                  "label": "Full (Jan 15, 10:30 AM)"
                },
                {
                  "value": "chart_datetime_seconds",
                  "label": "Full + Seconds (Jan 15, 10:30:05 AM)"
                }
              ]
            }
          ]
        },
        {
          "id": "y_axis_group",
          "label": "Y-axis",
          "layout": "single-column",
          "fields": [
            {
              "id": "multipleYAxis",
              "binds": "data_mapping.multiple_y_axis",
              "type": "boolean",
              "label": "Dual Y-axis",
              "default": false,
              "helperText": "Off: all columns on one axis (N allowed). On: split across left/right axes (capped at 2 columns)."
            },
            {
              "id": "y_axis_columns",
              "binds": "data_mapping.y_axis",
              "type": "y_axis_columns_list",
              "label": "Y-axis columns",
              "required": true,
              "helperText": "Numeric columns to plot. The column-name field overrides what appears in the legend; leave empty to use the data column name. Use In-stack to stack a subset of columns (columns left out stack-free draw independently \u2014 useful for a high-water total line).",
              "modeFieldId": "multipleYAxis",
              "maxInDualAxis": 2
            }
          ]
        },
        {
          "id": "series_group",
          "label": "Pivot",
          "helperText": "Use a column's distinct values to split one value column into multiple series \u2014 e.g. a `location` column with warehouse/north/south produces three series. Leave empty when every series is already its own column.",
          "layout": "row-4",
          "fields": [
            {
              "id": "series_column",
              "binds": "data_mapping.series",
              "type": "column_select",
              "label": "Pivot by column"
            }
          ]
        }
      ]
    },
    {
      "id": "chart_options",
      "label": "Chart Options",
      "subsections": [
        {
          "id": "display",
          "label": "Display",
          "layout": "row-4",
          "fields": [
            {
              "id": "chart_smooth",
              "binds": "options.chartSmooth",
              "type": "boolean",
              "label": "Smooth curves",
              "default": true
            },
            {
              "id": "chart_show_data_labels",
              "binds": "options.chartShowDataLabels",
              "type": "boolean",
              "label": "Data labels",
              "default": false
            },
            {
              "id": "chart_show_zoom_slider",
              "binds": "options.chartShowZoomSlider",
              "type": "boolean",
              "label": "Zoom slider",
              "default": false
            },
            {
              "id": "show_symbol",
              "binds": "options.showSymbol",
              "type": "boolean",
              "label": "Show point markers",
              "default": true,
              "helperText": "Turn off for dense time series to get a clean line."
            },
            {
              "id": "x_axis_label_rotate",
              "binds": "options.xAxisLabelRotate",
              "type": "enum",
              "label": "X-axis label angle",
              "helperText": "Rotate x-axis labels so long category names fit better. Best for charts with few categories; with many categories ECharts still thins labels to avoid overlap.",
              "default": 0,
              "options": [
                { "value": 0, "label": "Horizontal" },
                { "value": 30, "label": "30°" },
                { "value": 45, "label": "45°" },
                { "value": 90, "label": "Vertical (90°)" }
              ]
            }
          ]
        },
        {
          "id": "perf",
          "label": "Performance",
          "helperText": "Downsampling for \u226510k-point series. LTTB preserves visual shape; average/max preserve statistics.",
          "layout": "row-4",
          "fields": [
            {
              "id": "sampling",
              "binds": "options.sampling",
              "type": "enum",
              "label": "Downsampling",
              "default": "off",
              "options": [
                {
                  "value": "off",
                  "label": "Off (render every point)"
                },
                {
                  "value": "lttb",
                  "label": "LTTB (perceptual)"
                },
                {
                  "value": "average",
                  "label": "Average"
                },
                {
                  "value": "max",
                  "label": "Max"
                }
              ]
            }
          ]
        },
        {
          "id": "y_axis_range_left",
          "label": "Left Y-axis range",
          "helperText": "Auto lets the axis library scale to the data; uncheck to set manual bounds.",
          "layout": "row-4",
          "fields": [
            {
              "id": "y_left_min",
              "binds": "options.yAxisRange.left.min",
              "type": "nullable_number",
              "label": "Min",
              "default": null,
              "step": 1
            },
            {
              "id": "y_left_max",
              "binds": "options.yAxisRange.left.max",
              "type": "nullable_number",
              "label": "Max",
              "default": null,
              "step": 1
            },
            {
              "id": "y_left_scale",
              "binds": "options.yAxisRange.left.scale",
              "type": "enum",
              "label": "Scale",
              "default": "linear",
              "options": [
                {
                  "value": "linear",
                  "label": "Linear"
                },
                {
                  "value": "log",
                  "label": "Logarithmic"
                }
              ]
            }
          ]
        },
        {
          "id": "y_axis_range_right",
          "label": "Right Y-axis range",
          "helperText": "Only used when Dual Y-axis is on.",
          "layout": "row-4",
          "visibleWhen": {
            "field": "multipleYAxis",
            "operator": "truthy"
          },
          "fields": [
            {
              "id": "y_right_min",
              "binds": "options.yAxisRange.right.min",
              "type": "nullable_number",
              "label": "Min",
              "default": null,
              "step": 1
            },
            {
              "id": "y_right_max",
              "binds": "options.yAxisRange.right.max",
              "type": "nullable_number",
              "label": "Max",
              "default": null,
              "step": 1
            },
            {
              "id": "y_right_scale",
              "binds": "options.yAxisRange.right.scale",
              "type": "enum",
              "label": "Scale",
              "default": "linear",
              "options": [
                {
                  "value": "linear",
                  "label": "Linear"
                },
                {
                  "value": "log",
                  "label": "Logarithmic"
                }
              ]
            }
          ]
        },
        {
          "id": "tooltip_config",
          "label": "Tooltip",
          "helperText": "Mode controls when the tooltip appears on hover; Decimals + Units format the values inside.",
          "layout": "row-4",
          "fields": [
            {
              "id": "tooltip_mode",
              "binds": "options.tooltip.mode",
              "type": "enum",
              "label": "Mode",
              "default": "multi",
              "options": [
                {
                  "value": "multi",
                  "label": "All series"
                },
                {
                  "value": "single",
                  "label": "Single series"
                },
                {
                  "value": "hidden",
                  "label": "Hidden"
                }
              ]
            },
            {
              "id": "tooltip_decimals",
              "binds": "options.tooltip.decimals",
              "type": "nullable_number",
              "label": "Decimals",
              "default": null,
              "min": 0,
              "max": 10,
              "step": 1
            },
            {
              "id": "tooltip_units",
              "binds": "options.tooltip.units",
              "type": "text",
              "label": "Units suffix",
              "default": "",
              "placeholder": "e.g. %, \u00b0C, MB/s"
            }
          ]
        },
        {
          "id": "legend_config",
          "label": "Legend",
          "layout": "row-4",
          "fields": [
            {
              "id": "legend_show",
              "binds": "options.legend.show",
              "type": "boolean",
              "label": "Show legend",
              "default": true,
              "helperText": "When more than one series is present."
            },
            {
              "id": "legend_position",
              "binds": "options.legend.position",
              "type": "enum",
              "label": "Position",
              "default": "top",
              "helperText": "Top is the default and the recommended position. Left/right reserve ~135px of plot width for the legend column \u2014 widen the panel to compensate.",
              "options": [
                {
                  "value": "top",
                  "label": "Top"
                },
                {
                  "value": "bottom",
                  "label": "Bottom"
                },
                {
                  "value": "left",
                  "label": "Left"
                },
                {
                  "value": "right",
                  "label": "Right"
                }
              ],
              "visibleWhen": {
                "field": "legend_show",
                "operator": "truthy"
              }
            }
          ]
        },
        {
          "id": "thresholds_config",
          "label": "Y-axis Thresholds",
          "helperText": "Reference lines or color stops at specific Y values. Each threshold has a value, color, and optional label.",
          "layout": "single-column",
          "fields": [
            {
              "id": "y_thresholds",
              "binds": "options.yThresholds",
              "type": "threshold_list",
              "label": "Thresholds"
            }
          ]
        },
        {
          "id": "thresholds_render_mode_group",
          "label": "Threshold rendering",
          "layout": "row-4",
          "visibleWhen": {
            "field": "y_thresholds",
            "operator": "not_empty"
          },
          "fields": [
            {
              "id": "y_threshold_render_mode",
              "binds": "options.yThresholdRenderMode",
              "type": "enum",
              "label": "Render as",
              "default": "line",
              "options": [
                {
                  "value": "line",
                  "label": "Reference line at value"
                },
                {
                  "value": "color_segments",
                  "label": "Color the line by value"
                },
                {
                  "value": "both",
                  "label": "Both"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
