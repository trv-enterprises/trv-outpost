{
  "schema_version": "1",
  "chart_type": "number",
  "library": "react",
  "display": {
    "label": "Number",
    "icon": "StringInteger",
    "description": "A single value rendered as a large number with an optional unit"
  },
  "capabilities": {
    "requires_x_axis": false,
    "requires_y_axis": true,
    "multiple_y_axis": false,
    "single_axis_n_columns": false,
    "has_pivot_series": false,
    "has_axis_labels": false,
    "has_x_axis_format": false,
    "has_time_bucket": false,
    "has_sort_limit": false,
    "has_visible_columns": false,
    "has_filters": true,
    "has_aggregation": true,
    "has_sliding_window": false,
    "has_legend_config": false,
    "has_tooltip_config": false,
    "has_axis_range": false,
    "has_thresholds": false
  },
  "sections": [
    {
      "id": "data_mapping",
      "label": "Data Mapping",
      "subsections": [
        {
          "id": "value_group",
          "label": "Value",
          "helperText": "The number shows the first row's value for this column (after any aggregation).",
          "layout": "row-4",
          "fields": [
            {
              "id": "value_column",
              "binds": "data_mapping.y_axis[0]",
              "type": "column_select",
              "label": "Value column",
              "required": true,
              "helperText": "Numeric column to display."
            }
          ]
        }
      ]
    },
    {
      "id": "chart_options",
      "label": "Number Options",
      "subsections": [
        {
          "id": "number_style",
          "label": "Display",
          "layout": "row-4",
          "fields": [
            {
              "id": "number_size",
              "binds": "options.numberSize",
              "type": "enum",
              "label": "Value size (px)",
              "default": "120",
              "options": [
                { "value": "24", "label": "24 px" },
                { "value": "32", "label": "32 px" },
                { "value": "40", "label": "40 px" },
                { "value": "48", "label": "48 px" },
                { "value": "56", "label": "56 px" },
                { "value": "64", "label": "64 px" },
                { "value": "80", "label": "80 px" },
                { "value": "96", "label": "96 px" },
                { "value": "120", "label": "120 px" },
                { "value": "160", "label": "160 px" },
                { "value": "200", "label": "200 px" },
                { "value": "240", "label": "240 px" },
                { "value": "300", "label": "300 px" },
                { "value": "400", "label": "400 px" }
              ]
            },
            {
              "id": "number_unit",
              "binds": "options.numberUnit",
              "type": "text",
              "label": "Unit suffix",
              "default": "",
              "placeholder": "e.g. °F, %, psi",
              "helperText": "Rendered inline after the value, same size."
            }
          ]
        }
      ]
    }
  ]
}
