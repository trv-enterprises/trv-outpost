{
  "schema_version": "1",
  "chart_type": "number",
  "library": "react",
  "display": {
    "label": "Number",
    "icon": "StringInteger",
    "description": "A single value rendered as a large number with an optional unit"
  },
  "capabilities": {
    "requires_x_axis": false,
    "requires_y_axis": true,
    "multiple_y_axis": false,
    "single_axis_n_columns": false,
    "has_pivot_series": false,
    "has_axis_labels": false,
    "has_x_axis_format": false,
    "has_time_bucket": false,
    "has_sort_limit": false,
    "has_visible_columns": false,
    "has_filters": true,
    "has_aggregation": true,
    "has_sliding_window": false,
    "has_legend_config": false,
    "has_tooltip_config": false,
    "has_axis_range": false,
    "has_thresholds": false
  },
  "sections": [
    {
      "id": "data_mapping",
      "label": "Data Mapping",
      "subsections": [
        {
          "id": "value_group",
          "label": "Value",
          "helperText": "The number shows the first row's value for this column (after any aggregation).",
          "layout": "row-4",
          "fields": [
            {
              "id": "value_column",
              "binds": "data_mapping.y_axis[0]",
              "type": "column_select",
              "label": "Value column",
              "required": true,
              "helperText": "Numeric column to display."
            }
          ]
        }
      ]
    },
    {
      "id": "chart_options",
      "label": "Number Options",
      "subsections": [
        {
          "id": "number_value_format",
          "label": "Value format",
          "helperText": "How to render the value. The format implies the raw value's unit — pick Duration when the value is seconds, Date/Time when it's a timestamp — so no query math is needed.",
          "layout": "row-4",
          "fields": [
            {
              "id": "number_format",
              "binds": "options.numberFormat",
              "type": "enum",
              "label": "Format",
              "default": "auto",
              "options": [
                { "value": "auto", "label": "Auto (source precision)" },
                { "value": "plain", "label": "Plain number (1,234.5)" },
                { "value": "compact", "label": "Compact (1.2M, 3.4K)" },
                { "value": "duration", "label": "Duration from seconds (2d 3h 4m)" },
                { "value": "duration_clock", "label": "Duration clock (HH:MM:SS)" },
                { "value": "datetime", "label": "Date / time (value is a timestamp)" }
              ]
            },
            {
              "id": "number_date_format",
              "binds": "options.numberDateFormat",
              "type": "enum",
              "label": "Date/time style",
              "default": "datetime",
              "helperText": "Only used when Format is Date / time.",
              "visibleWhen": { "field": "number_format", "operator": "eq", "value": "datetime" },
              "options": [
                { "value": "date", "label": "Date (Jan 15)" },
                { "value": "time", "label": "Time (10:30 AM)" },
                { "value": "time_seconds", "label": "Time + seconds (10:30:05 AM)" },
                { "value": "datetime", "label": "Date + time (Jan 15, 10:30 AM)" },
                { "value": "datetime_seconds", "label": "Date + time + seconds" }
              ]
            }
          ]
        },
        {
          "id": "number_style",
          "label": "Display",
          "layout": "row-4",
          "fields": [
            {
              "id": "number_size",
              "binds": "options.numberSize",
              "type": "enum",
              "label": "Value size (px)",
              "default": "120",
              "options": [
                { "value": "24", "label": "24 px" },
                { "value": "32", "label": "32 px" },
                { "value": "40", "label": "40 px" },
                { "value": "48", "label": "48 px" },
                { "value": "56", "label": "56 px" },
                { "value": "64", "label": "64 px" },
                { "value": "80", "label": "80 px" },
                { "value": "96", "label": "96 px" },
                { "value": "120", "label": "120 px" },
                { "value": "160", "label": "160 px" },
                { "value": "200", "label": "200 px" },
                { "value": "240", "label": "240 px" },
                { "value": "300", "label": "300 px" },
                { "value": "400", "label": "400 px" }
              ]
            },
            {
              "id": "number_decimals",
              "binds": "options.numberDecimals",
              "type": "enum",
              "label": "Decimal places",
              "default": "auto",
              "helperText": "Auto keeps the source precision (up to 2 places). Pick a number to force exactly that many decimals.",
              "options": [
                { "value": "auto", "label": "Auto" },
                { "value": "0", "label": "0" },
                { "value": "1", "label": "1" },
                { "value": "2", "label": "2" },
                { "value": "3", "label": "3" },
                { "value": "4", "label": "4" }
              ]
            },
            {
              "id": "number_unit",
              "binds": "options.numberUnit",
              "type": "text",
              "label": "Unit suffix",
              "default": "",
              "placeholder": "e.g. °F, %, psi",
              "helperText": "Rendered inline after the value, same size."
            }
          ]
        }
      ]
    }
  ]
}
