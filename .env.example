# TRV Outpost — environment configuration
#
# This file is OPTIONAL. The defaults in docker-compose.deploy.yml
# already produce a working dashboard at http://localhost.
#
# Copy and edit only if you want to customize:
#   cp .env.example .env

# =============================================================================
# IMAGE / RELEASE
# =============================================================================

# Pin to a specific version, or leave as `latest` for the most recent
# tagged release. See https://github.com/trv-enterprises/trve-dashboard/releases
# IMAGE_TAG=v0.10.0

# =============================================================================
# NETWORKING
# =============================================================================

# Domain Caddy serves on. `localhost` is fine for evaluation; switch
# to your real hostname (e.g. `dashboard.example.com`) for a public
# deployment and Caddy will request a Let's Encrypt cert automatically.
# Public DNS + ports 80/443 reachable from the internet are required
# for cert issuance.
# DOMAIN=localhost

# Override host ports (defaults: 80 / 443). Useful if those are taken.
# HTTP_PORT=8080
# HTTPS_PORT=8443

# =============================================================================
# AI BUILDER (optional)
# =============================================================================

# Anthropic API key — enables the AI chart builder. Without this,
# the dashboard works fully; the AI Builder option is just hidden.
# Get a key at https://console.anthropic.com/.
# ANTHROPIC_API_KEY=sk-ant-api03-…

# =============================================================================
# CLERK SIGN-IN (optional)
# =============================================================================

# Set BOTH to enable Clerk-backed browser sign-in (email + Google +
# Apple, etc.). When unset, the dashboard uses its bootstrap-chain
# identity flow described in udoc/docs/getting-started.md. See also
# udoc/docs/clerk-sso.md for setup walkthrough.
# CLERK_SECRET_KEY=sk_test_…
# CLERK_PUBLISHABLE_KEY=pk_test_…

# =============================================================================
# EXTERNAL CONNECTIVITY (optional, advanced)
# =============================================================================

# host:port the server can be reached at from outside the docker
# network — only needed if you have an external service (e.g.
# ts-store) that dials back to this server's inbound WebSocket.
# Leave empty for the standard quickstart.
# DASHBOARD_HOST=192.168.1.10:3001
